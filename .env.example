# LLM Configuration
# Provider: openai, anthropic, or azure
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic API Key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Azure OpenAI settings (required if LLM_PROVIDER=azure)
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key
# AZURE_OPENAI_BASE_URL=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# GitHub Configuration
# Personal Access Token with repo + issues + pull_requests scopes
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repository-name

# Git Identity (used for commits)
GIT_USER_NAME=LangGraph Agent
GIT_USER_EMAIL=agent@langgraph.local

# Workspace Configuration
# Directory where repositories are cloned during agent execution
WORKSPACE_DIR=/tmp/workspace

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Agent Configuration
MAX_ITERATIONS=10
RECURSION_LIMIT=50

# Docker Image (VPS / production deployment only)
# Set to the GHCR image built by the CD workflow to pull instead of building locally.
# Leave unset for local development (docker-compose will build from source).
# DOCKER_IMAGE=ghcr.io/your-org/langgraph-poc:latest
