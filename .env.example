# LLM Configuration
# Provider: openai or anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic API Key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# GitHub Configuration
# Personal Access Token with repo + issues + pull_requests scopes
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repository-name

# Git Identity (used for commits)
GIT_USER_NAME=LangGraph Agent
GIT_USER_EMAIL=agent@langgraph.local

# Workspace Configuration
# Directory where repositories are cloned during agent execution
WORKSPACE_DIR=/tmp/workspace

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Agent Configuration
MAX_ITERATIONS=10
RECURSION_LIMIT=50
